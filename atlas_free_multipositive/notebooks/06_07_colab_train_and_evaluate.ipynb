{"cells":[{"cell_type":"markdown","metadata":{},"source":["# 06-07 Colab Train And Evaluate\n","\n","This notebook is a Colab-oriented combined smoke training and retrieval evaluation run for the isolated atlas-free multi-positive pipeline.\n","\n","It trains a small 3D CNN brain encoder against frozen precomputed SPECTER/SPECTER2 text embeddings using weighted multi-positive InfoNCE."]},{"cell_type":"markdown","metadata":{},"source":["## Required Files\n","\n","Upload or mount a folder containing:\n","\n","- `atlas_free_multipositive/cache/unified_jsonl/splits/train.jsonl`\n","- `atlas_free_multipositive/cache/unified_jsonl/splits/val.jsonl`\n","- `atlas_free_multipositive/cache/unified_jsonl/text_registry.jsonl`\n","- `atlas_free_multipositive/cache/text_embeddings/specter_text_cache.pt`\n","- Any NIfTI maps referenced by the JSONL rows, usually `atlas_free_multipositive/cache/maps/`\n","- The PubMed packed ALE tensor cache referenced by the JSONL rows, currently `atlas_free_multipositive/data/ale_caches/atlas_free_4mm_fwhm9_crop_float16.pt`\n","\n","So: `cache/` is not always enough. If your PubMed rows point to `atlas_free_multipositive/data/ale_caches/...`, upload that file too, or rewrite `tensor_path` in the JSONL."]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Colab setup. If you cloned the repo, set PROJECT_ROOT to that clone.\n","from pathlib import Path\n","import os, sys, json, math, random\n","\n","PROJECT_ROOT = Path.cwd()\n","while PROJECT_ROOT != PROJECT_ROOT.parent and not (PROJECT_ROOT / 'atlas_free_multipositive').exists():\n","    PROJECT_ROOT = PROJECT_ROOT.parent\n","os.chdir(PROJECT_ROOT)\n","sys.path.insert(0, str(PROJECT_ROOT))\n","sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n","print('PROJECT_ROOT =', PROJECT_ROOT)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Optional: install project dependencies in Colab if needed.\n","# Run this cell only if imports fail.\n","# %pip install torch pandas numpy nibabel nilearn pyyaml tqdm\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["from pathlib import Path\n","required = [\n","    Path('atlas_free_multipositive/cache/unified_jsonl/splits/train.jsonl'),\n","    Path('atlas_free_multipositive/cache/unified_jsonl/splits/val.jsonl'),\n","    Path('atlas_free_multipositive/cache/unified_jsonl/text_registry.jsonl'),\n","    Path('atlas_free_multipositive/cache/text_embeddings/specter_text_cache.pt'),\n","]\n","for p in required:\n","    print(p, p.exists())\n","missing = [str(p) for p in required if not p.exists()]\n","if missing:\n","    raise FileNotFoundError('Missing required files: ' + repr(missing))\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["import torch\n","from torch.utils.data import DataLoader\n","import torch.nn.functional as F\n","\n","from atlas_free_multipositive.training.datasets import UnifiedMapTextDataset\n","from atlas_free_multipositive.training.collators import MultiPositiveCollator\n","from atlas_free_multipositive.training.losses import multi_positive_infonce\n","from atlas_free_multipositive.training.model_wrappers import TextProjectionHead, build_brain_encoder\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print('device =', device)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Hyperparameters for a first Colab smoke run.\n","BATCH_SIZE = 8\n","EPOCHS = 3\n","MAX_TRAIN_STEPS = 300      # set None for full epoch training\n","MAX_VAL_BATCHES = 50\n","POSITIVES_PER_MAP = 3\n","TARGET_SHAPE = (36, 45, 38) # matches current PubMed ALE packed cache; mixed NIfTI maps are resized in-batch\n","LR_BRAIN = 1e-4\n","LR_TEXT_PROJ = 1e-4\n","TEMPERATURE = 0.07\n","\n","train_ds = UnifiedMapTextDataset('atlas_free_multipositive/cache/unified_jsonl/splits/train.jsonl')\n","val_ds = UnifiedMapTextDataset('atlas_free_multipositive/cache/unified_jsonl/splits/val.jsonl')\n","print('train rows', len(train_ds), 'val rows', len(val_ds))\n","\n","collator = MultiPositiveCollator(positives_per_map=POSITIVES_PER_MAP, target_shape=TARGET_SHAPE, seed=42)\n","train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True, num_workers=0, collate_fn=collator)\n","val_loader = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False, num_workers=0, collate_fn=collator)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Load frozen SPECTER/SPECTER2 embeddings that were precomputed in notebook 05.\n","text_cache = torch.load('atlas_free_multipositive/cache/text_embeddings/specter_text_cache.pt', map_location='cpu', weights_only=False)\n","print('cached text embeddings:', len(text_cache))\n","\n","def lookup_text_embeddings(texts):\n","    missing = [t for t in texts if t not in text_cache]\n","    if missing:\n","        raise KeyError(f'{len(missing)} sampled texts are missing from specter_text_cache.pt. Example: {missing[0][:200]}')\n","    return torch.stack([torch.as_tensor(text_cache[t], dtype=torch.float32) for t in texts])\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Model being trained:\n","# brain map [B,1,X,Y,Z] -> ALE3DCNNEncoder -> 384d\n","# frozen SPECTER text embeddings [T,768] -> trainable TextProjectionHead -> 384d\n","brain_encoder = build_brain_encoder(out_dim=384).to(device)\n","text_projector = TextProjectionHead(in_dim=768, hidden_dim=512, out_dim=384).to(device)\n","\n","optimizer = torch.optim.AdamW([\n","    {'params': brain_encoder.parameters(), 'lr': LR_BRAIN},\n","    {'params': text_projector.parameters(), 'lr': LR_TEXT_PROJ},\n"], weight_decay=1e-4)\n","\n","print(brain_encoder)\n","print(text_projector)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["def run_epoch(loader, train=True, max_batches=None):\n","    brain_encoder.train(train)\n","    text_projector.train(train)\n","    losses = []\n","    for step, batch in enumerate(loader):\n","        if max_batches is not None and step >= max_batches:\n","            break\n","        volume = batch['volume'].to(device, non_blocking=True)\n","        raw_text = lookup_text_embeddings(batch['texts']).to(device, non_blocking=True)\n","        pos_mask = batch['pos_mask'].to(device)\n","        pos_weights = batch['pos_weights'].to(device)\n","        with torch.set_grad_enabled(train):\n","            brain_emb = brain_encoder(volume)\n","            text_emb = text_projector(raw_text)\n","            loss = multi_positive_infonce(brain_emb, text_emb, pos_mask, pos_weights, temperature=TEMPERATURE)\n","            if train:\n","                optimizer.zero_grad(set_to_none=True)\n","                loss.backward()\n","                torch.nn.utils.clip_grad_norm_(list(brain_encoder.parameters()) + list(text_projector.parameters()), 1.0)\n","                optimizer.step()\n","        losses.append(float(loss.detach().cpu()))\n","        if train and step % 25 == 0:\n","            print(f'step {step:04d} loss {losses[-1]:.4f}')\n","    return sum(losses) / max(1, len(losses))\n","\n","history = []\n","for epoch in range(1, EPOCHS + 1):\n","    train_loss = run_epoch(train_loader, train=True, max_batches=MAX_TRAIN_STEPS)\n","    val_loss = run_epoch(val_loader, train=False, max_batches=MAX_VAL_BATCHES)\n","    row = {'epoch': epoch, 'train_loss': train_loss, 'val_loss': val_loss}\n","    history.append(row)\n","    print(row)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Save checkpoint.\n","out_dir = Path('atlas_free_multipositive/outputs/runs/colab_multipositive_smoke')\n","out_dir.mkdir(parents=True, exist_ok=True)\n","torch.save({\n","    'brain_encoder': brain_encoder.state_dict(),\n","    'text_projector': text_projector.state_dict(),\n","    'history': history,\n","    'target_shape': TARGET_SHAPE,\n","}, out_dir / 'checkpoint.pt')\n","json.dump(history, open(out_dir / 'history.json', 'w'), indent=2)\n","print('saved', out_dir)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Lightweight retrieval diagnostic on sampled positives from validation batches.\n","# This measures whether each brain map ranks its sampled positives above other sampled texts in the same eval pool.\n","@torch.no_grad()\n","def collect_eval_embeddings(loader, max_batches=50):\n","    brain_encoder.eval(); text_projector.eval()\n","    brain_chunks, text_chunks, masks = [], [], []\n","    row_offset = 0\n","    for b, batch in enumerate(loader):\n","        if b >= max_batches:\n","            break\n","        volume = batch['volume'].to(device)\n","        raw_text = lookup_text_embeddings(batch['texts']).to(device)\n","        brain_chunks.append(F.normalize(brain_encoder(volume).detach().cpu(), dim=1))\n","        text_chunks.append(F.normalize(text_projector(raw_text).detach().cpu(), dim=1))\n","        masks.append(batch['pos_mask'].detach().cpu())\n","    return torch.cat(brain_chunks), torch.cat(text_chunks), torch.block_diag(*masks)\n","\n","brain_eval, text_eval, pos_mask_eval = collect_eval_embeddings(val_loader, max_batches=MAX_VAL_BATCHES)\n","scores = brain_eval @ text_eval.T\n","print(scores.shape, pos_mask_eval.shape)\n"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["from atlas_free_multipositive.evaluation.metrics import ranking_metrics\n","metrics = ranking_metrics(scores, pos_mask_eval, ks=(1,5,10,50))\n","print(json.dumps(metrics, indent=2))\n","json.dump(metrics, open(out_dir / 'sampled_positive_retrieval_metrics.json', 'w'), indent=2)\n"]}],"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","pygments_lexer":"ipython3"}},"nbformat":4,"nbformat_minor":5}
